{
  "name": "doomscrollingjobs",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.6.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "deploy:cloud-run": "bash ./scripts/deploy-cloud-run.sh",
    "check:ui-system": "node ./scripts/check-ui-system.mjs",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "capture:ui": "playwright test tests/ui-artifacts.spec.ts --project=chromium --reporter=line",
    "eval:correctness": "node --disable-warning=ExperimentalWarning --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-transform-types --loader ./scripts/alias-loader.mjs ./scripts/eval-repo.mts --layer correctness --no-report",
    "eval:workflows": "node --disable-warning=ExperimentalWarning --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-transform-types --loader ./scripts/alias-loader.mjs ./scripts/eval-repo.mts --layer workflows --no-report",
    "eval:ui": "node --disable-warning=ExperimentalWarning --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-transform-types --loader ./scripts/alias-loader.mjs ./scripts/eval-repo.mts --layer ui --no-report",
    "eval:ui-artifacts": "node --disable-warning=ExperimentalWarning --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-transform-types --loader ./scripts/alias-loader.mjs ./scripts/eval-repo.mts --layer ui-artifacts --no-report",
    "eval": "node --disable-warning=ExperimentalWarning --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-transform-types --loader ./scripts/alias-loader.mjs ./scripts/eval-repo.mts",
    "check": "npm run lint && npm run typecheck && npm run check:ui-system && npm run build",
    "test:ui-contracts": "playwright test tests/ui-contracts.spec.ts --project=chromium",
    "smoke:packet": "node --disable-warning=ExperimentalWarning --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-transform-types --loader ./scripts/alias-loader.mjs ./scripts/smoke-test-packet.mts",
    "smoke:packet-persistence": "node --disable-warning=ExperimentalWarning --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-transform-types --loader ./scripts/alias-loader.mjs ./scripts/smoke-packet-persistence.mts",
    "smoke:import-contract": "node --disable-warning=ExperimentalWarning --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-transform-types --loader ./scripts/alias-loader.mjs ./scripts/smoke-import-contract.mts",
    "smoke:server-action-workflow": "node --disable-warning=ExperimentalWarning --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-transform-types --loader ./scripts/alias-loader.mjs ./scripts/smoke-server-action-workflow.mts",
    "smoke:routes": "node --disable-warning=ExperimentalWarning --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-transform-types --loader ./scripts/alias-loader.mjs ./scripts/smoke-routes.mts",
    "smoke:workflow-state": "node --disable-warning=ExperimentalWarning --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-transform-types --loader ./scripts/alias-loader.mjs ./scripts/smoke-workflow-state.mts",
    "smoke:workflow-transition": "node --disable-warning=ExperimentalWarning --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-transform-types --loader ./scripts/alias-loader.mjs ./scripts/smoke-workflow-transition.mts",
    "diagnostic:external-sourcing": "node --disable-warning=ExperimentalWarning --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-transform-types --loader ./scripts/alias-loader.mjs ./scripts/diagnostic-external-sourcing.mts",
    "backfill:job-review-copy": "node --experimental-transform-types --loader ./scripts/alias-loader.mjs ./scripts/backfill-job-review-copy.mts",
    "cleanup:packet-generation": "node --experimental-transform-types --loader ./scripts/alias-loader.mjs ./scripts/clear-packet-generation.mts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.0.0",
    "docx": "^9.6.1",
    "next": "^16.0.0",
    "pdf-parse": "^2.4.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^16.0.0",
    "typescript": "^5.0.0"
  }
}
